#!/bin/bash

menu_option_three() {
  echo "        Performance settings"
}

menu_option_four() {
  echo "        Language settings"
}

press_enter() {
  echo ""
  echo -n "	Press Enter to continue "
  read
  clear
}

incorrect_selection() {
  echo "Incorrect selection! Try again."
}

menu_option_one() {

until [ "$selection" = "0" ]; do
  clear
  echo ""
  echo "    	3  -  Performance"
  echo "    	4  -  Language"
  echo "    	0  -  Back"
  echo ""
  echo -n "  Enter selection: "
  read selection
  echo ""
  case $selection in
    3 ) clear ; menu_option_three ; press_enter ;;
    4 ) clear ; menu_option_four ; press_enter ;;
    0 ) clear ; spa+s ;;
    * ) clear ; incorrect_selection ; press_enter ;;
  esac
done 
}

menu_option_two() {
  echo "        spa mod created by: Zaedian"
}

press_enter() {
  echo ""
  echo -n "	Press Enter to continue "
  read
  clear
}

incorrect_selection() {
  echo "Incorrect selection! Try again."
}

until [ "$selection" = "0" ]; do
  clear
  echo ""
  echo "    	1  -  Settings"
  echo "    	2  -  About"
  echo "    	0  -  Exit"
  echo ""
  echo -n "  Enter selection: "
  read selection
  echo ""
  case $selection in
    1 ) clear ; menu_option_one ; press_enter ;;
    2 ) clear ; menu_option_two ; press_enter ;;
    0 ) clear ; spa ;;
    * ) clear ; incorrect_selection ; press_enter ;;
  esac
done 
